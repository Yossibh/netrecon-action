{
  "name": "netrecon-action",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Correlated network posture checks in CI. DNS, HTTP, TLS, email, CDN.",
  "author": "Yossi Ben Hagai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yossibh/netrecon-action.git"
  },
  "homepage": "https://netrecon.pages.dev",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "all": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0"
  }
}
